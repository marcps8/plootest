# Local development — ver README.md
# Producción: Vault → Vercel/Railway (nunca commitear valores reales)

# Postgres (Neon pooled en prod Vercel, direct en worker Railway)
DATABASE_URL=postgresql://ploot:ploot_dev@localhost:5432/ploot?sslmode=disable
DATABASE_URL_DIRECT=postgresql://ploot:ploot_dev@localhost:5432/ploot?sslmode=disable

# Upstash Redis — SOLO rate limit (local: contenedor redis)
REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# AWS SQS — cola de publicación + DLQ (local: LocalStack)
AWS_REGION=eu-central-1
AWS_ENDPOINT_URL=http://localhost:4566
SQS_QUEUE_URL=http://localhost:4566/000000000000/ploot-publish-jobs

# Auth (Edge middleware + Node handlers)
JWT_SECRET=change-me-in-production

# Proveedor externo (mock local)
PROVIDER_BASE_URL=http://localhost:4000
OAUTH_CLIENT_SECRET=change-me-in-production

# Cifrado tokens OAuth (32 bytes hex) — path Vault en prod
TOKEN_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# Worker
WORKER_CONCURRENCY=5
PG_POOL_MAX=10

# Datadog (prod)
DD_SERVICE=ploot-scheduler
DD_ENV=development
DD_SITE=datadoghq.eu
