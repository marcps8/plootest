{
  "name": "ploot-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "pretest": "npm run build --prefix ../shared",
    "test": "vitest run"
  },
  "dependencies": {
